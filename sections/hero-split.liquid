<style>
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 88vh;
    overflow: hidden;
  }

  /* Columna imagen */
  .hero-split__img-col {
    position: relative;
    overflow: hidden;
    background: var(--cm-light);
  }

  .hero-split__img-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.78) saturate(0.8);
    transition: transform 1s ease;
    display: block;
  }

  .hero-split__img-col:hover img { transform: scale(1.02); }

  .hero-split__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 55%, rgba(250,250,247,0.12) 100%);
    pointer-events: none;
  }

  /* Year stamp */
  .hero-split__year {
    position: absolute;
    top: 48px;
    left: 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 1;
  }

  .hero-split__year-num {
    font-family: var(--cm-font-serif);
    font-size: 13px;
    font-style: italic;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.06em;
  }

  .hero-split__year-line {
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,0.25);
  }

  .hero-split__year-label {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    font-family: var(--cm-font-sans);
  }

  /* Columna contenido */
  .hero-split__content-col {
    background: var(--cm-off);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 88px;
    position: relative;
  }

  .hero-split__eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 9.5px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--cm-gold);
    font-weight: 500;
    margin-bottom: 36px;
    font-family: var(--cm-font-sans);
  }

  .hero-split__eyebrow-dash {
    width: 30px;
    height: 1px;
    background: var(--cm-gold);
    opacity: 0.55;
  }

  .hero-split__h1 {
    font-family: var(--cm-font-serif);
    font-size: clamp(46px, 5vw, 78px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--cm-navy);
    margin-bottom: 10px;
  }

  .hero-split__h1 em {
    font-style: italic;
    color: var(--cm-gold);
  }

  .hero-split__h1-sub {
    font-family: var(--cm-font-serif);
    font-size: clamp(14px, 1.5vw, 20px);
    font-weight: 400;
    font-style: italic;
    color: var(--cm-text-light);
    margin-bottom: 36px;
    letter-spacing: 0.02em;
  }

  .hero-split__body {
    font-size: 14.5px;
    line-height: 1.8;
    color: var(--cm-text-mid);
    max-width: 400px;
    margin-bottom: 52px;
    font-family: var(--cm-font-sans);
  }

  .hero-split__btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .hero-split__content-col { padding: 64px 48px; }
  }

  @media (max-width: 767px) {
    .hero-split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-split__img-col {
      height: 55vw;
      min-height: 240px;
    }

    .hero-split__content-col {
      padding: 48px 24px;
    }

    .hero-split__h1 {
      font-size: clamp(36px, 10vw, 54px);
    }

    .hero-split__year { top: 24px; left: 24px; }
  }
</style>

<section class="hero-split">

  <!-- Columna imagen -->
  <div class="hero-split__img-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      {% # theme-check-disable-next-line RemoteAsset %}
      <img src="https://placehold.co/900x1100/1A1814/F4F2EE?text=Jamón+Ibérico" alt="Jamón ibérico de bellota" width="900" height="1100" loading="eager">
    {%- endif -%}

    <div class="hero-split__img-overlay"></div>

    <div class="hero-split__year">
      <span class="hero-split__year-num">III</span>
      <span class="hero-split__year-line"></span>
      <span class="hero-split__year-label">Generaciones</span>
    </div>
  </div>

  <!-- Columna contenido -->
  <div class="hero-split__content-col">

    <div class="hero-split__eyebrow">
      <span class="hero-split__eyebrow-dash"></span>
      {{ section.settings.eyebrow | default: 'Productos Ibéricos de Alicante' }}
    </div>

    <h1 class="hero-split__h1">{{ section.settings.heading | default: 'Sabor <em>auténtico</em>, tradición ibérica' }}</h1>

    {%- if section.settings.subheading != blank -%}
      <p class="hero-split__h1-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="hero-split__body">{{ section.settings.body }}</p>
    {%- endif -%}

    <div class="hero-split__btns">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/all' }}" class="cm-btn-primary">
          {{ section.settings.cta_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '/collections/packs-y-regalos' }}" class="cm-btn-gold-border">
          {{ section.settings.cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero dividido",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del hero"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Productos Ibéricos de Alicante"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Titular",
      "default": "<p>Sabor <em>auténtico</em>, tradición ibérica</p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo (cursiva)",
      "default": "Authentic taste, Iberian tradition"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Párrafo de descripción",
      "default": "Seleccionamos las mejores piezas ibéricas para llevar a tu mesa la esencia de la dehesa española. Calidad artesanal desde Alicante."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Texto botón principal",
      "default": "Ver colección"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Enlace botón principal"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Texto botón secundario",
      "default": "Packs regalo"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Enlace botón secundario"
    }
  ],
  "presets": [
    {
      "name": "Hero dividido"
    }
  ]
}
{% endschema %}
