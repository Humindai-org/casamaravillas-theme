    },
    {
      "type": "text",
      "id": "tier3_price",
      "label": "Precio desde (€)",
      "default": "89"
    },
    {
      "type": "url",
      "id": "tier3_url",
      "label": "Enlace"
    }
  ],
  "presets": [
