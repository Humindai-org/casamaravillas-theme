{% comment %}
  jamones-quality-tiers.liquid
  Franja compacta con 3 tiers de calidad ibérica.
  Cada card es un filtro clickable — selecciona/deselecciona la calidad en el grid de productos.
{% endcomment %}

<style>
  .qt-{{ section.id }} {
    background: var(--cm-off);
    padding: 40px 72px 48px;
  }

  /* ── Header ── */
  .qt__header-{{ section.id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .qt__eyebrow-{{ section.id }} {
    display: block;
    margin-bottom: 14px;
  }

  .qt__heading-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.2;
  }

  .qt__heading-{{ section.id }} em {
    font-style: italic;
    color: var(--cm-gold);
  }

  /* ── Grid de 3 columnas ── */
  .qt__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--cm-border);
    border: 1px solid var(--cm-border);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Card — ahora es un <a> clickable ── */
  .qt__tier-{{ section.id }} {
    background: var(--cm-white);
    padding: 28px 32px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border-top: 3px solid transparent;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.28s ease, box-shadow 0.28s ease, background 0.2s;
    position: relative;
  }

  .qt__tier-{{ section.id }}:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 40px rgba(196, 151, 58, 0.1),
      0 4px 12px rgba(0, 20, 40, 0.06);
    z-index: 2;
    background: var(--cm-white);
  }

  .qt__tier-{{ section.id }}:focus-visible {
    outline: 2px solid var(--cm-gold);
    outline-offset: -2px;
  }

  /* ── Estado activo ── */
  .qt__tier-{{ section.id }}.is-active {
    background: rgba(196, 151, 58, 0.04);
  }

  .qt__active-pill-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--cm-font-sans);
    font-size: 8.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-top: 10px;
  }

  .qt__active-pill-{{ section.id }}::before {
    content: '✕';
    font-size: 8px;
    opacity: 0.7;
  }

  /* Indicador de "seleccionable" en estado inactivo */
  .qt__hint-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 8.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cm-text-light);
    margin-top: 10px;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .qt__tier-{{ section.id }}:hover .qt__hint-{{ section.id }} {
    opacity: 1;
  }

  /* ── Borde superior por tier ── */
  .qt__tier-gold-{{ section.id }}   { border-top-color: #C4973A; }
  .qt__tier-silver-{{ section.id }} { border-top-color: #A8A8A8; }
  .qt__tier-bronze-{{ section.id }} { border-top-color: #A07040; }

  /* Sombra interior sutil en estado activo */
  .qt__tier-gold-{{ section.id }}.is-active   { box-shadow: inset 0 0 0 1px rgba(196,151,58,0.18); }
  .qt__tier-silver-{{ section.id }}.is-active { box-shadow: inset 0 0 0 1px rgba(168,168,168,0.18); }
  .qt__tier-bronze-{{ section.id }}.is-active { box-shadow: inset 0 0 0 1px rgba(160,112,64,0.18); }

  /* ── Etiqueta Oro / Plata / Bronce ── */
  .qt__tier-label-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 8px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .qt__tier-gold-{{ section.id }}   .qt__tier-label-{{ section.id }} { color: #a07520; }
  .qt__tier-silver-{{ section.id }} .qt__tier-label-{{ section.id }} { color: #707070; }
  .qt__tier-bronze-{{ section.id }} .qt__tier-label-{{ section.id }} { color: #6e4820; }

  /* ── Puntos de calidad ── */
  .qt__dots-{{ section.id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }

  .qt__dot-{{ section.id }} {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cm-border2);
  }

  .qt__dot-{{ section.id }}.is-filled { background: var(--cm-gold); }

  /* ── Nombre ── */
  .qt__name-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.3;
    flex: 1;
  }

  /* ── Tablet ── */
  @media (max-width: 1023px) {
    .qt-{{ section.id }} {
      padding: 32px 40px 40px;
    }
    .qt__tier-{{ section.id }} {
      padding: 24px 24px 28px;
    }
    .qt__name-{{ section.id }} {
      font-size: 16px;
    }
  }

  /* ── Mobile: horizontal scroll ── */
  @media (max-width: 767px) {
    .qt-{{ section.id }} {
      padding: 32px 0 36px;
    }
    .qt__header-{{ section.id }} {
      padding: 0 24px;
    }
    .qt__grid-{{ section.id }} {
      grid-template-columns: none;
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 0;
      background: transparent;
      border: none;
      padding: 0 24px 16px;
      scrollbar-width: none;
    }
    .qt__grid-{{ section.id }}::-webkit-scrollbar { display: none; }
    .qt__tier-{{ section.id }} {
      min-width: 220px;
      flex-shrink: 0;
      scroll-snap-align: start;
      border: 1px solid var(--cm-border);
      border-top: 3px solid transparent;
      margin-right: 10px;
    }
    .qt__tier-gold-{{ section.id }}   { border-top-color: #C4973A; }
    .qt__tier-silver-{{ section.id }} { border-top-color: #A8A8A8; }
    .qt__tier-bronze-{{ section.id }} { border-top-color: #A07040; }
    .qt__tier-{{ section.id }}:last-child { margin-right: 0; }
  }
</style>

{%- assign tier_filter_tags = 'calidad_bellota,calidad_cebo-de-campo,calidad_cebo' | split: ',' -%}

<section class="qt-{{ section.id }}" id="qt-section-{{ section.id }}">
  <div class="qt__header-{{ section.id }}">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cm-eyebrow qt__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="qt__heading-{{ section.id }}">
        {%- assign words = section.settings.heading | split: ' ' -%}
        {%- for word in words -%}
          {%- if forloop.last -%}
            <em>{{ word }}</em>
          {%- else -%}
            {{ word }}{% unless forloop.last %} {% endunless %}
          {%- endif -%}
        {%- endfor -%}
      </h2>
    {%- endif -%}
  </div>

  {%- assign tiers       = 'gold,silver,bronze' | split: ',' -%}
  {%- assign tier_labels = 'Oro,Plata,Bronce' | split: ',' -%}
  {%- assign tier_dots   = '5,4,3' | split: ',' -%}

  <div class="qt__grid-{{ section.id }}">
    {%- for i in (1..3) -%}
      {%- assign tier_class = tiers[forloop.index0] -%}
      {%- assign tier_label = tier_labels[forloop.index0] -%}
      {%- assign dot_count  = tier_dots[forloop.index0] | plus: 0 -%}
      {%- assign tier_tag   = tier_filter_tags[forloop.index0] -%}
      {%- assign name_key   = 'tier' | append: i | append: '_name' -%}

      {%- assign is_active = false -%}
      {%- for t in current_tags -%}
        {%- if t == tier_tag -%}{%- assign is_active = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if is_active -%}
        {%- assign tier_href = collection.url -%}
      {%- else -%}
        {%- assign tier_href = collection.url | append: '/' | append: tier_tag -%}
      {%- endif -%}

      <a
        class="qt__tier-{{ section.id }} qt__tier-{{ tier_class }}-{{ section.id }}{% if is_active %} is-active{% endif %}"
        href="{{ tier_href }}"
        aria-pressed="{{ is_active }}"
        aria-label="Filtrar por {{ section.settings[name_key] }}{% if is_active %} — clic para quitar filtro{% endif %}"
      >
        <span class="qt__tier-label-{{ section.id }}">{{ tier_label }}</span>

        <div class="qt__dots-{{ section.id }}" aria-hidden="true">
          {%- for d in (1..5) -%}
            <span class="qt__dot-{{ section.id }}{% if d <= dot_count %} is-filled{% endif %}"></span>
          {%- endfor -%}
        </div>

        <span class="qt__name-{{ section.id }}">{{ section.settings[name_key] }}</span>

        {%- if is_active -%}
          <span class="qt__active-pill-{{ section.id }}">Filtro activo</span>
        {%- else -%}
          <span class="qt__hint-{{ section.id }}">Ver selección</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Jamones — Calidad",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Nuestra calidad"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titular",
      "default": "Tres niveles de excelencia"
    },
    {
      "type": "header",
      "content": "🥇 Tier 1 — Oro"
    },
    {
      "type": "text",
      "id": "tier1_name",
      "label": "Nombre",
      "default": "Bellota 100% Ibérico"
    },
    {
      "type": "header",
      "content": "🥈 Tier 2 — Plata"
    },
    {
      "type": "text",
      "id": "tier2_name",
      "label": "Nombre",
      "default": "Cebo de Campo Ibérico"
    },
    {
      "type": "header",
      "content": "🥉 Tier 3 — Bronce"
    },
    {
      "type": "text",
      "id": "tier3_name",
      "label": "Nombre",
      "default": "Cebo Ibérico"
    }
  ],
  "presets": [
    {
      "name": "Jamones — Calidad"
    }
  ]
}
{% endschema %}
