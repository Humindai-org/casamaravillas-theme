<style>
  .newsletter-section {
    background: var(--cm-navy);
    padding: 100px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .newsletter-section__seal {
    border: 1.5px solid var(--cm-gold);
    max-width: 480px;
    width: 100%;
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }

  .newsletter-section__seal::before,
  .newsletter-section__seal::after {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(196, 151, 58, 0.22);
    pointer-events: none;
  }

  .newsletter-section__seal::after {
    inset: 10px;
    border-color: rgba(196, 151, 58, 0.1);
  }

  .newsletter-section__eyebrow {
    font-family: var(--cm-font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.52em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 20px;
  }

  .newsletter-section__divider {
    width: 48px;
    height: 1px;
    background: rgba(196, 151, 58, 0.45);
    margin: 0 auto 24px;
  }

  .newsletter-section__title {
    font-family: var(--cm-font-serif);
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 400;
    color: white;
    line-height: 1.35;
    margin-bottom: 16px;
  }

  .newsletter-section__title em { font-style: italic; }

  .newsletter-section__body {
    font-family: var(--cm-font-sans);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 340px;
  }

  .newsletter-section__btn {
    display: inline-block;
    padding: 14px 36px;
    background: var(--cm-gold);
    color: white;
    border: none;
    font-family: var(--cm-font-sans);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s;
  }

  .newsletter-section__btn:hover { background: var(--cm-gold-h); }

  .newsletter-section__btn:focus-visible {
    outline: 2px solid white;
    outline-offset: 3px;
  }

  @media (max-width: 600px) {
    .newsletter-section { padding: 72px 24px; }
    .newsletter-section__seal { padding: 48px 28px; }
  }
</style>

<section class="newsletter-section">
  <div class="newsletter-section__seal">
    <p class="newsletter-section__eyebrow">{{ section.settings.eyebrow | default: 'Club Casa Maravillas' }}</p>
    <div class="newsletter-section__divider"></div>
    <h2 class="newsletter-section__title">{{ section.settings.title | default: 'Curado por tres generaciones. <em>Recibido por la tuya.</em>' }}</h2>
    {%- if section.settings.body != blank -%}
      <p class="newsletter-section__body">{{ section.settings.body }}</p>
    {%- endif -%}
    <a href="{{ section.settings.cta_url | default: '/pages/suscripcion' }}" class="newsletter-section__btn">
      {{ section.settings.cta_label | default: 'Unirme al club' }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Club Casa Maravillas"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Suscríbete al placer de lo <em>auténtico.</em></p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Descripción",
      "default": "En Casa Maravillas seleccionamos por ti solo lo mejor. Recíbelo en casa, en el momento justo, con la calidad que nos define."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Quiero suscribirme"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace del botón"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
