<style>
  .trust-band {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 2px solid var(--cm-gold);
    border-bottom: 1px solid var(--cm-border);
    background: var(--cm-off);
  }

  .trust-band__cell {
    padding: 40px 28px;
    border-right: 1px solid var(--cm-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .trust-band__cell:last-child { border-right: none; }

  .trust-band__icon {
    width: 32px;
    height: 32px;
    color: var(--cm-gold);
    flex-shrink: 0;
  }

  .trust-band__title {
    font-size: 12px;
    font-weight: 500;
    color: var(--cm-text);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--cm-font-sans);
    line-height: 1.3;
  }

  .trust-band__desc {
    font-size: 12px;
    color: var(--cm-text-mid);
    line-height: 1.55;
    font-family: var(--cm-font-sans);
  }

  @media (max-width: 767px) {
    .trust-band {
      grid-template-columns: 1fr 1fr;
    }
    .trust-band__cell:nth-child(2) { border-right: none; }
    .trust-band__cell:nth-child(3) {
      border-right: 1px solid var(--cm-border);
      border-top: 1px solid var(--cm-border);
    }
    .trust-band__cell:nth-child(4) {
      border-top: 1px solid var(--cm-border);
    }
    .trust-band__cell { padding: 32px 20px; }
  }
</style>

{%- assign icons = 'truck|shield|snowflake|gift' | split: '|' -%}

<div class="trust-band">
  {%- for block in section.blocks -%}
    {%- assign icon_name = icons[forloop.index0] -%}
    <div class="trust-band__cell" {{ block.shopify_attributes }}>
      <svg class="trust-band__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case icon_name -%}
          {%- when 'truck' -%}
            <rect x="1" y="3" width="15" height="13" rx="1"/><path d="m16 8 4 1 3 4v4h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          {%- when 'shield' -%}
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          {%- when 'snowflake' -%}
            <line x1="12" y1="2" x2="12" y2="22"/><path d="m17 7-5 5-5-5"/><path d="m17 17-5-5-5 5"/><line x1="2" y1="12" x2="22" y2="12"/><path d="m7 7 5 5 5-5"/><path d="m7 17 5-5 5 5"/>
          {%- when 'gift' -%}
            <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
        {%- endcase -%}
      </svg>
      <div>
        <p class="trust-band__title">{{ block.settings.title }}</p>
        <p class="trust-band__desc">{{ block.settings.description }}</p>
      </div>
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Banda de confianza",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Elemento",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Envío gratis"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción",
          "default": "A partir de €80 en Peninsula"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banda de confianza",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "title": "Envío gratis",
            "description": "A partir de €80 en Península"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Calidad garantizada",
            "description": "Tres generaciones de artesanía ibérica"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Embalaje especial",
            "description": "Conservación en frío garantizada"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "title": "Packaging regalo",
            "description": "Presentación premium para regalar"
          }
        }
      ]
    }
  ]
}
{% endschema %}
