<style>
  /* ── Wrapper sticky ── */
  .site-header {
    background: var(--cm-white);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: box-shadow 0.3s ease;
  }

  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(13,27,42,0.08);
  }

  /* ── Fila 1: Logo + utilidades ── */
  .site-header__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 64px;
    height: 88px;
    border-bottom: 1px solid var(--cm-border);
  }

  .site-header__top-left {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .site-header__logo {
    flex: 0 0 auto;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__logo img {
    height: 72px;
    width: auto;
    display: block;
  }

  .site-header__top-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .site-header__top-right a {
    text-decoration: none;
    color: var(--cm-text-mid);
    font-size: 12px;
    letter-spacing: 0.04em;
    font-family: var(--cm-font-sans);
    transition: color 0.3s;
    white-space: nowrap;
  }

  .site-header__top-right a:not(.site-header__cart):hover { color: var(--cm-navy); }

  /* Cart */
  .site-header__cart {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 20px;
    background: var(--cm-white);
    border: 1.5px solid var(--cm-navy);
    color: var(--cm-navy);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.12em;
    font-weight: 500;
    font-family: var(--cm-font-sans);
    cursor: pointer;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }

  .site-header__cart:hover {
    background: var(--cm-navy);
    border-color: var(--cm-navy);
    color: var(--cm-white);
  }

  .site-header__cart-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: var(--cm-gold);
    color: var(--cm-white);
    font-size: 9px;
    font-weight: 600;
    border-radius: 50%;
  }

  /* ── Fila 2: Navegación de producto ── */
  .site-header__nav {
    border-bottom: 1px solid var(--cm-border);
    display: flex;
    justify-content: center;
  }

  .site-header__nav-list {
    display: flex;
    list-style: none;
    height: 48px;
  }

  .site-header__nav-list > li {
    position: relative;
    display: flex;
    align-items: center;
  }

  .site-header__nav-list > li > a {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0 28px;
    height: 100%;
    text-decoration: none;
    color: var(--cm-text-mid);
    font-size: 12px;
    letter-spacing: 0.06em;
    font-weight: 400;
    font-family: var(--cm-font-sans);
    text-transform: uppercase;
    transition: color 0.3s;
    white-space: nowrap;
  }

  .site-header__nav-list > li > a:hover,
  .site-header__nav-list > li:hover > a {
    color: var(--cm-navy);
  }

  .site-header__nav-list > li > a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 28px;
    right: 28px;
    height: 2px;
    background: var(--cm-gold);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .site-header__nav-list > li:hover > a::after {
    transform: scaleX(1);
  }

  .nav-chevron {
    width: 10px;
    height: 10px;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .site-header__nav-list > li:hover .nav-chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .site-header__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    background: var(--cm-white);
    border: 1px solid var(--cm-border);
    border-top: 2px solid var(--cm-gold);
    min-width: 210px;
    padding: 8px 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    box-shadow: 0 8px 24px rgba(13,27,42,0.08);
    z-index: 200;
    list-style: none;
  }

  .site-header__nav-list > li:hover .site-header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .site-header__dropdown a {
    display: block;
    padding: 10px 22px;
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--cm-text-mid);
    font-family: var(--cm-font-sans);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .site-header__dropdown a:hover {
    color: var(--cm-navy);
    background: var(--cm-off);
  }

  .site-header__dropdown-divider {
    height: 1px;
    background: var(--cm-border);
    margin: 6px 0;
  }

  /* ── Hamburger (mobile) ── */
  .site-header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    cursor: pointer;
    background: none;
    border: none;
  }

  .site-header__hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--cm-navy);
    transition: transform 0.3s, opacity 0.3s;
  }

  /* ── Mobile drawer ── */
  .site-header__drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
  }

  .site-header__drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(13,27,42,0.5);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .site-header__drawer-panel {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 300px;
    background: var(--cm-white);
    padding: 32px 28px;
    transform: translateX(-100%);
    transition: transform 0.35s ease;
    overflow-y: auto;
  }

  .site-header__drawer.is-open { display: block; }
  .site-header__drawer.is-open .site-header__drawer-overlay { opacity: 1; }
  .site-header__drawer.is-open .site-header__drawer-panel { transform: translateX(0); }

  .site-header__drawer-close {
    display: block;
    margin-left: auto;
    margin-bottom: 32px;
    font-size: 22px;
    color: var(--cm-navy);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
  }

  .site-header__drawer-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .site-header__drawer-nav > li {
    border-bottom: 1px solid var(--cm-border);
  }

  .site-header__drawer-nav > li > a,
  .site-header__drawer-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 0;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--cm-text);
    font-family: var(--cm-font-sans);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.3s;
    text-align: left;
  }

  .site-header__drawer-nav > li > a:hover,
  .site-header__drawer-toggle:hover { color: var(--cm-gold); }

  .site-header__drawer-toggle.is-open .nav-chevron { transform: rotate(180deg); }

  .site-header__drawer-sub {
    display: none;
    padding-bottom: 8px;
  }

  .site-header__drawer-sub.is-open { display: block; }

  .site-header__drawer-sub a {
    display: block;
    padding: 9px 0 9px 12px;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--cm-text-mid);
    font-family: var(--cm-font-sans);
    text-decoration: none;
    transition: color 0.2s;
  }

  .site-header__drawer-sub a:hover { color: var(--cm-gold); }

  .drawer-divider {
    height: 1px;
    background: var(--cm-border);
    margin: 4px 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .site-header__top { padding: 0 32px; }
    .site-header__nav-list > li > a { padding: 0 18px; }
    .site-header__nav-list > li > a::after { left: 18px; right: 18px; }
  }

  @media (max-width: 767px) {
    .site-header__top {
      padding: 0 20px;
      height: 64px;
    }
    .site-header__top-left { display: none; }
    .site-header__top-right { display: none; }
    .site-header__logo img { height: 48px; }
    .site-header__nav { display: none; }
    .site-header__hamburger { display: flex; }

    .site-header__top {
      display: grid;
      grid-template-columns: auto 1fr auto;
    }

    .site-header__hamburger-wrap { display: flex; }
  }
</style>

{%- assign main_nav = linklists[section.settings.main_menu] -%}

<header class="site-header" id="site-header">

  <!-- Fila 1: Logo + utilidades -->
  <div class="site-header__top">

    <div class="site-header__top-left">
      <button class="site-header__hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-drawer" id="hamburger-btn">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      <img src="{{ 'logo2-sin-bg.png' | asset_url }}"
           alt="{{ shop.name }}"
           loading="eager">
    </a>

    <!-- Derecha: enlaces configurables + carrito -->
    <div class="site-header__top-right">
      {%- if section.settings.nosotros_url != blank -%}
        <a href="{{ section.settings.nosotros_url }}">{{ section.settings.nosotros_label | default: 'Nosotros' }}</a>
      {%- endif -%}
      {%- if section.settings.guia_url != blank -%}
        <a href="{{ section.settings.guia_url }}">{{ section.settings.guia_label | default: 'Guía del Ibérico' }}</a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="site-header__cart" aria-label="Carrito de compra" onclick="if(typeof openCart!=='undefined'){openCart();return false;}">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span>Cesta</span>
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count" aria-label="{{ cart.item_count }} artículos">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>


  </div>

  <!-- Fila 2: Navegación principal desde menú de Shopify -->
  {%- if main_nav.links.size > 0 -%}
    <nav class="site-header__nav" aria-label="Navegación principal">
      <ul class="site-header__nav-list">
        {%- for link in main_nav.links -%}
          <li>
            <a href="{{ link.url }}">
              {{ link.title }}
              {%- if link.links.size > 0 -%}
                <svg class="nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M2 3.5l3 3 3-3"/></svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="site-header__dropdown">
                {%- for child in link.links -%}
                  {%- if forloop.last and link.links.size > 1 -%}
                    <li class="site-header__dropdown-divider"></li>
                  {%- endif -%}
                  <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}

</header>

<!-- Mobile drawer -->
<div class="site-header__drawer" id="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Menú de navegación">
  <div class="site-header__drawer-overlay" id="drawer-overlay"></div>
  <div class="site-header__drawer-panel">
    <button class="site-header__drawer-close" aria-label="Cerrar menú" id="drawer-close">✕</button>
    <nav>
      <ul class="site-header__drawer-nav">

        {%- for link in main_nav.links -%}
          {%- if link.links.size > 0 -%}
            <li>
              <button class="site-header__drawer-toggle" aria-expanded="false" data-target="drawer-{{ link.handle }}">
                {{ link.title }}
                <svg class="nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M2 3.5l3 3 3-3"/></svg>
              </button>
              <div class="site-header__drawer-sub" id="drawer-{{ link.handle }}">
                {%- for child in link.links -%}
                  {%- if forloop.last and link.links.size > 1 -%}
                    <div class="drawer-divider"></div>
                  {%- endif -%}
                  <a href="{{ child.url }}">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </li>
          {%- else -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.nosotros_url != blank -%}
          <li><a href="{{ section.settings.nosotros_url }}">{{ section.settings.nosotros_label | default: 'Nosotros' }}</a></li>
        {%- endif -%}
        {%- if section.settings.guia_url != blank -%}
          <li><a href="{{ section.settings.guia_url }}">{{ section.settings.guia_label | default: 'Guía del Ibérico' }}</a></li>
        {%- endif -%}
        <li><a href="{{ routes.cart_url }}">Cesta ({{ cart.item_count }})</a></li>

      </ul>
    </nav>
  </div>
</div>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 10);
  }, { passive: true });

  const hamburger = document.getElementById('hamburger-btn');
  const drawer = document.getElementById('mobile-drawer');
  const drawerClose = document.getElementById('drawer-close');
  const drawerOverlay = document.getElementById('drawer-overlay');

  function openDrawer() {
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', openDrawer);
  drawerClose.addEventListener('click', closeDrawer);
  drawerOverlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

  document.querySelectorAll('.site-header__drawer-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      const sub = document.getElementById(targetId);
      const isOpen = sub.classList.contains('is-open');
      document.querySelectorAll('.site-header__drawer-sub').forEach(s => s.classList.remove('is-open'));
      document.querySelectorAll('.site-header__drawer-toggle').forEach(b => {
        b.classList.remove('is-open');
        b.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        sub.classList.add('is-open');
        btn.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Cabecera",
  "class": "site-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Menú principal (barra de navegación)"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menú de navegación",
      "info": "Ve a Admin → Navegación para crear o editar este menú. Los elementos de primer nivel aparecen como pestañas; sus sub-elementos forman el desplegable.",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Barra superior — enlace Nosotros"
    },
    {
      "type": "url",
      "id": "nosotros_url",
      "label": "Página de destino"
    },
    {
      "type": "text",
      "id": "nosotros_label",
      "label": "Texto del enlace",
      "default": "Nosotros"
    },
    {
      "type": "header",
      "content": "Barra superior — enlace Guía del Ibérico"
    },
    {
      "type": "url",
      "id": "guia_url",
      "label": "Página de destino"
    },
    {
      "type": "text",
      "id": "guia_label",
      "label": "Texto del enlace",
      "default": "Guía del Ibérico"
    }
  ]
}
{% endschema %}
