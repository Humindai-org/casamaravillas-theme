<style>
  .ido-{{ section.id }} {
    background: var(--cm-white);
    padding: 96px 24px;
    border-bottom: 1px solid var(--cm-border);
    scroll-margin-top: 56px;
  }

  .ido__inner-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .ido__header-{{ section.id }} {
    text-align: center;
    margin-bottom: 16px;
  }

  .ido__eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--cm-font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 18px;
  }

  .ido__heading-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .ido__heading-{{ section.id }} em {
    font-style: italic;
    color: var(--cm-gold);
  }

  .ido__subhead-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 14px;
    font-weight: 300;
    color: var(--cm-text-mid);
    line-height: 1.75;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  /* ── Grid 4 col ── */
  .ido__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--cm-border);
    border: 1px solid var(--cm-border);
  }

  /* ── Card ── */
  .ido__card-{{ section.id }} {
    background: var(--cm-off);
    padding: 32px 28px 36px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 3px solid var(--cm-gold);
    transition: transform 0.28s ease, box-shadow 0.28s ease, background 0.2s;
    text-decoration: none;
  }

  .ido__card-{{ section.id }}[href]:hover,
  .ido__card-{{ section.id }}[href]:focus {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(0,41,75,0.07);
    background: var(--cm-white);
    z-index: 2;
  }

  .ido__card-{{ section.id }}[href]:focus-visible {
    outline: 2px solid var(--cm-gold);
    outline-offset: -2px;
  }

  /* ── Type badge (DOP / IGP) ── */
  .ido__type-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--cm-font-sans);
    font-size: 7.5px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cm-gold);
    border: 1px solid rgba(196,151,58,0.35);
    padding: 3px 8px;
    margin-bottom: 18px;
    align-self: flex-start;
  }

  /* ── Region ── */
  .ido__region-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 8.5px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cm-text-light);
    margin-bottom: 10px;
  }

  /* ── DO Name ── */
  .ido__name-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(17px, 1.8vw, 22px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.25;
    margin-bottom: 8px;
  }

  /* ── Municipality ── */
  .ido__municipality-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 12px;
    font-weight: 400;
    color: var(--cm-text-light);
    margin-bottom: 20px;
  }

  /* ── Divider ── */
  .ido__divider-{{ section.id }} {
    width: 28px;
    height: 1px;
    background: rgba(196,151,58,0.3);
    margin-bottom: 16px;
  }

  /* ── Flavor profile label ── */
  .ido__flavor-label-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 7.5px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cm-text-light);
    margin-bottom: 6px;
  }

  /* ── Flavor text ── */
  .ido__flavor-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 13px;
    font-weight: 300;
    color: var(--cm-text-mid);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 24px;
  }

  /* ── CTA link ── */
  .ido__link-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--cm-font-sans);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-top: auto;
    transition: gap 0.2s;
  }

  .ido__card-{{ section.id }}[href]:hover .ido__link-{{ section.id }} {
    gap: 10px;
  }

  .ido__link-{{ section.id }} svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* ── Tablet: 2×2 ── */
  @media (max-width: 1023px) {
    .ido__grid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); }
    .ido__card-{{ section.id }} { padding: 28px 24px 32px; }
  }

  /* ── Mobile: 1 col ── */
  @media (max-width: 600px) {
    .ido-{{ section.id }} { padding: 64px 24px; }
    .ido__grid-{{ section.id }} { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ido__card-{{ section.id }},
    .ido__link-{{ section.id }} { transition: none; }
  }
</style>

<section class="ido-{{ section.id }}" id="denominaciones">
  <div class="ido__inner-{{ section.id }}">

    <header class="ido__header-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ido__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="ido__heading-{{ section.id }}">
        {%- assign h_words = section.settings.heading | default: 'Denominaciones de Origen Protegidas' | split: ' ' -%}
        {%- for word in h_words -%}
          {%- if forloop.last -%}<em>{{ word }}</em>{%- else -%}{{ word }} {%- endif -%}
        {%- endfor -%}
      </h2>
      {%- if section.settings.subhead != blank -%}
        <p class="ido__subhead-{{ section.id }}">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </header>

    <div class="ido__grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign card_tag = 'div' -%}
        {%- if block.settings.link != blank -%}
          {%- assign card_tag = 'a' -%}
        {%- endif -%}

        <{{ card_tag }}
          class="ido__card-{{ section.id }}"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.do_type != blank -%}
            <span class="ido__type-{{ section.id }}">{{ block.settings.do_type }}</span>
          {%- endif -%}

          {%- if block.settings.region != blank -%}
            <span class="ido__region-{{ section.id }}">{{ block.settings.region }}</span>
          {%- endif -%}

          <h3 class="ido__name-{{ section.id }}">{{ block.settings.name | default: 'Denominación' }}</h3>

          {%- if block.settings.municipality != blank -%}
            <p class="ido__municipality-{{ section.id }}">{{ block.settings.municipality }}</p>
          {%- endif -%}

          <div class="ido__divider-{{ section.id }}" aria-hidden="true"></div>

          {%- if block.settings.flavor != blank -%}
            <p class="ido__flavor-label-{{ section.id }}">Perfil de sabor</p>
            <p class="ido__flavor-{{ section.id }}">{{ block.settings.flavor }}</p>
          {%- endif -%}

          {%- if block.settings.link != blank and block.settings.link_label != blank -%}
            <span class="ido__link-{{ section.id }}" aria-hidden="true">
              {{ block.settings.link_label }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          {%- endif -%}

        </{{ card_tag }}>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Ibérico — Denominaciones",
  "tag": "section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "do",
      "name": "Denominación de Origen",
      "settings": [
        {
          "type": "text",
          "id": "do_type",
          "label": "Tipo de protección",
          "default": "D.O.P.",
          "info": "Ej: D.O.P., I.G.P."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre de la Denominación",
          "default": "DOP Jabugo"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Región / Comunidad",
          "default": "Huelva — Andalucía"
        },
        {
          "type": "text",
          "id": "municipality",
          "label": "Municipio de referencia",
          "default": "Jabugo, Huelva"
        },
        {
          "type": "textarea",
          "id": "flavor",
          "label": "Perfil de sabor",
          "default": "Aroma intenso y complejo, sabor dulce con matices de frutos secos y hierbas de la sierra onubense. Considerado el jamón ibérico de referencia mundial."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace a la colección (opcional)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto del enlace",
          "default": "Ver selección"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "El origen importa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título H2",
      "default": "Denominaciones de Origen Protegidas"
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Cuatro territorios, cuatro personalidades distintas. Cada Denominación de Origen garantiza el origen, la raza y el proceso de elaboración del jamón ibérico."
    }
  ],
  "presets": [
    {
      "name": "Ibérico — Denominaciones",
      "blocks": [
        {
          "type": "do",
          "settings": {
            "do_type": "D.O.P.",
            "name": "DOP Jabugo",
            "region": "Huelva — Andalucía",
            "municipality": "Jabugo, Huelva",
            "flavor": "Aroma intenso y complejo, notas de frutos secos y hierbas de sierra. Grasa muy infiltrada con alto contenido en ácido oleico. Referente mundial del jamón ibérico de bellota.",
            "link_label": "Jamón de Jabugo"
          }
        },
        {
          "type": "do",
          "settings": {
            "do_type": "I.G.P.",
            "name": "IGP Guijuelo",
            "region": "Salamanca — Castilla y León",
            "municipality": "Guijuelo, Salamanca",
            "flavor": "Sabor suave y delicado, curación lenta favorecida por el microclima de la sierra de Béjar. Menos salado que otras denominaciones, con textura de grasa más firme.",
            "link_label": "Jamón de Guijuelo"
          }
        },
        {
          "type": "do",
          "settings": {
            "do_type": "D.O.P.",
            "name": "DOP Dehesa de Extremadura",
            "region": "Cáceres y Badajoz — Extremadura",
            "municipality": "Extremadura",
            "flavor": "Carácter robusto y pronunciado, aromas terrosos de la dehesa extremeña. Alto contenido en grasa infiltrada. Curación en secaderos de montaña con variaciones térmicas marcadas.",
            "link_label": "Jamón de Extremadura"
          }
        },
        {
          "type": "do",
          "settings": {
            "do_type": "D.O.P.",
            "name": "DOP Los Pedroches",
            "region": "Córdoba — Andalucía",
            "municipality": "Valle de Los Pedroches, Córdoba",
            "flavor": "Sabor elegante y equilibrado, con notas de bellota muy definidas. La dehesa cordobesa aporta una grasa de color rosado-amarillento con alta proporción de ácido oleico.",
