<style>
  @keyframes ido-fade-up-{{ section.id }} {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section ── */
  .ido-{{ section.id }} {
    background: var(--cm-off);
    padding: 96px 24px;
    border-bottom: 1px solid var(--cm-border);
    scroll-margin-top: 56px;
  }

  .ido__inner-{{ section.id }} {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .ido__header-{{ section.id }} {
    text-align: center;
    margin-bottom: 56px;
    animation: ido-fade-up-{{ section.id }} 0.6s ease both;
  }

  .ido__eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--cm-font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 14px;
  }

  .ido__heading-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .ido__heading-{{ section.id }} em {
    color: var(--cm-gold);
    font-style: italic;
    font-weight: 400;
  }

  .ido__subhead-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 15px;
    color: #6A6560;
    font-weight: 300;
    line-height: 1.75;
    max-width: 580px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .ido__grid-{{ section.id }} {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }

  /* ── Card ── */
  .ido__card-{{ section.id }} {
    position: relative;
    border-radius: 5px;
    overflow: hidden;
    height: 500px;
    flex: 1;
    min-width: 220px;
    cursor: default;
    box-shadow: 0 4px 18px rgba(0,0,0,0.10);
    transition: transform 0.45s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.45s ease,
                flex 0.45s cubic-bezier(0.16,1,0.3,1);
  }

  .ido__card-{{ section.id }}:nth-child(1) { animation: ido-fade-up-{{ section.id }} 0.6s ease 0.10s both; }
  .ido__card-{{ section.id }}:nth-child(2) { animation: ido-fade-up-{{ section.id }} 0.6s ease 0.21s both; }
  .ido__card-{{ section.id }}:nth-child(3) { animation: ido-fade-up-{{ section.id }} 0.6s ease 0.32s both; }
  .ido__card-{{ section.id }}:nth-child(4) { animation: ido-fade-up-{{ section.id }} 0.6s ease 0.44s both; }

  .ido__card-{{ section.id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 28px 56px rgba(0,0,0,0.26);
    flex: 1.35;
  }

  /* ── Card color schemes ── */
  .ido__card--navy-{{ section.id }} {
    background: linear-gradient(160deg, #111E35 0%, #1C2B4A 100%);
  }
  .ido__card--cognac-{{ section.id }} {
    background: linear-gradient(160deg, #1C1408 0%, #2A1F10 100%);
  }
  .ido__card--umber-{{ section.id }} {
    background: linear-gradient(160deg, #200E08 0%, #2E1A10 100%);
  }
  .ido__card--forest-{{ section.id }} {
    background: linear-gradient(160deg, #101A14 0%, #1A2820 100%);
  }

  /* ── Front ── */
  .ido__front-{{ section.id }} {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px 24px 24px;
    transition: opacity 0.25s ease;
  }

  .ido__card-{{ section.id }}:hover .ido__front-{{ section.id }} {
    opacity: 0;
    pointer-events: none;
  }

  .ido__front-region-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    font-weight: 400;
    margin-bottom: 12px;
  }

  .ido__front-name-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 24px;
    font-weight: 500;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ido__front-town-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin-top: 8px;
    font-weight: 300;
  }

  .ido__front-sep-{{ section.id }} {
    height: 1px;
    background: rgba(196,151,58,0.3);
    margin-bottom: 14px;
  }

  .ido__front-region-it-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 13px;
    font-style: italic;
    color: var(--cm-gold);
    opacity: 0.8;
  }

  .ido__front-hint-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-top: 4px;
  }

  /* ── Reveal ── */
  .ido__reveal-{{ section.id }} {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 28px;
    transform: translateY(100%);
    transition: transform 0.48s cubic-bezier(0.16,1,0.3,1);
  }

  .ido__card--navy-{{ section.id }} .ido__reveal-{{ section.id }}   { background: linear-gradient(175deg, rgba(17,30,53,0.95) 0%, #1C2B4A 100%); }
  .ido__card--cognac-{{ section.id }} .ido__reveal-{{ section.id }} { background: linear-gradient(175deg, rgba(28,20,8,0.95) 0%, #2A1F10 100%); }
  .ido__card--umber-{{ section.id }} .ido__reveal-{{ section.id }}  { background: linear-gradient(175deg, rgba(32,14,8,0.95) 0%, #2E1A10 100%); }
  .ido__card--forest-{{ section.id }} .ido__reveal-{{ section.id }} { background: linear-gradient(175deg, rgba(16,26,20,0.95) 0%, #1A2820 100%); }

  .ido__card-{{ section.id }}:hover .ido__reveal-{{ section.id }} {
    transform: translateY(0);
  }

  /* Top accent line on reveal */
  .ido__reveal-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--cm-gold);
  }

  /* Reveal items — base state */
  .ido__ri-{{ section.id }} {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .ido__card-{{ section.id }}:hover .ido__ri-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered delays */
  .ido__ri1-{{ section.id }} { transition-delay: 0.12s; }
  .ido__ri2-{{ section.id }} { transition-delay: 0.20s; }
  .ido__ri3-{{ section.id }} { transition-delay: 0.28s; }
  .ido__ri4-{{ section.id }} { transition-delay: 0.36s; }

  /* Reveal divider */
  .ido__reveal-div-{{ section.id }} {
    height: 1px;
    background: rgba(196,151,58,0.4);
    margin: 14px 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease 0.2s;
  }

  .ido__card-{{ section.id }}:hover .ido__reveal-div-{{ section.id }} {
    transform: scaleX(1);
  }

  .ido__reveal-name-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 24px;
    font-weight: 500;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }

  .ido__reveal-flavor-label-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 6px;
    font-weight: 500;
  }

  .ido__reveal-flavor-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 13px;
    color: rgba(232,237,245,0.9);
    line-height: 1.65;
    font-weight: 300;
  }

  .ido__reveal-detail-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 11.5px;
    color: rgba(255,255,255,0.38);
    line-height: 1.55;
    font-style: italic;
    margin-top: 10px;
  }

  .ido__reveal-sep-{{ section.id }} {
    height: 1px;
    background: rgba(196,151,58,0.25);
    margin-bottom: 10px;
  }

  .ido__reveal-region-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: 12px;
    font-style: italic;
    color: var(--cm-gold);
  }

  .ido__reveal-link-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--cm-font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-top: 10px;
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .ido__reveal-link-{{ section.id }}:hover { gap: 10px; }
  .ido__reveal-link-{{ section.id }}:focus-visible { outline: 1px solid var(--cm-gold); outline-offset: 2px; }

  /* ── Mobile ── */
  @media (max-width: 1023px) {
    .ido__grid-{{ section.id }} { gap: 8px; }
    .ido__card-{{ section.id }} { min-width: 200px; }
  }

  @media (max-width: 767px) {
    .ido-{{ section.id }} { padding: 64px 16px; }

    .ido__grid-{{ section.id }} {
      flex-direction: column;
      gap: 16px;
    }

    .ido__card-{{ section.id }} {
      height: auto;
      min-width: unset;
      flex: none;
    }

    .ido__card-{{ section.id }}:hover {
      transform: none;
      flex: none;
    }

    /* On mobile: stack front + reveal, hide hover-only elements */
    .ido__front-{{ section.id }} {
      position: relative;
      inset: auto;
      padding: 28px 24px 20px;
    }

    .ido__front-hint-{{ section.id }} { display: none; }

    .ido__reveal-{{ section.id }} {
      position: relative;
      inset: auto;
      transform: none;
      padding: 0 24px 28px;
    }

    .ido__reveal-{{ section.id }}::before { display: none; }

    .ido__ri-{{ section.id }} {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .ido__reveal-div-{{ section.id }} {
      transform: scaleX(1);
      transition: none;
    }

    .ido__reveal-name-{{ section.id }} { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ido__card-{{ section.id }},
    .ido__front-{{ section.id }},
    .ido__reveal-{{ section.id }},
    .ido__ri-{{ section.id }},
    .ido__reveal-div-{{ section.id }},
    .ido__reveal-link-{{ section.id }} { transition: none; animation: none; }

    .ido__card-{{ section.id }}:nth-child(1),
    .ido__card-{{ section.id }}:nth-child(2),
    .ido__card-{{ section.id }}:nth-child(3),
    .ido__card-{{ section.id }}:nth-child(4) { animation: none; opacity: 1; }

    .ido__card-{{ section.id }}:hover { transform: none; }

    .ido__reveal-{{ section.id }} { transform: none; }
    .ido__reveal-div-{{ section.id }} { transform: scaleX(1); }
    .ido__ri-{{ section.id }} { opacity: 1; transform: none; }
  }
</style>

<section class="ido-{{ section.id }}" id="denominaciones">
  <div class="ido__inner-{{ section.id }}">

    <header class="ido__header-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ido__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        {%- assign h_parts = section.settings.heading | split: ' ' -%}
        {%- assign h_last = h_parts | last -%}
        {%- assign h_rest = section.settings.heading | remove_last: h_last | strip -%}
        <h2 class="ido__heading-{{ section.id }}">
          {{ h_rest }} <em>{{ h_last }}</em>
        </h2>
      {%- endif -%}
      {%- if section.settings.subhead != blank -%}
        <p class="ido__subhead-{{ section.id }}">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </header>

    <div class="ido__grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign card_color = block.settings.color | default: 'navy' -%}
        {%- assign region_parts = block.settings.region | split: '—' -%}
        {%- assign community = region_parts | last | strip -%}

        <div
          class="ido__card-{{ section.id }} ido__card--{{ card_color }}-{{ section.id }}"
          {{ block.shopify_attributes }}
        >

          {%- comment %} FRONT {%- endcomment %}
          <div class="ido__front-{{ section.id }}">
            <div>
              <p class="ido__front-region-{{ section.id }}">{{ block.settings.region }}</p>
              <h3 class="ido__front-name-{{ section.id }}">{{ block.settings.name }}</h3>
              {%- if block.settings.municipality != blank -%}
                <p class="ido__front-town-{{ section.id }}">{{ block.settings.municipality }}</p>
              {%- endif -%}
            </div>
            <div>
              <div class="ido__front-sep-{{ section.id }}"></div>
              <p class="ido__front-region-it-{{ section.id }}">{{ community }}</p>
              <p class="ido__front-hint-{{ section.id }}">Pasar el ratón para saber más</p>
            </div>
          </div>

          {%- comment %} REVEAL {%- endcomment %}
          <div class="ido__reveal-{{ section.id }}">

            <div class="ido__ri-{{ section.id }} ido__ri1-{{ section.id }}">
              <h3 class="ido__reveal-name-{{ section.id }}">{{ block.settings.name }}</h3>
            </div>

            <div class="ido__reveal-div-{{ section.id }}"></div>

            {%- if block.settings.flavor != blank -%}
              <div class="ido__ri-{{ section.id }} ido__ri2-{{ section.id }}">
                <p class="ido__reveal-flavor-label-{{ section.id }}">Perfil de sabor</p>
                <p class="ido__reveal-flavor-{{ section.id }}">{{ block.settings.flavor }}</p>
              </div>
            {%- endif -%}

            {%- if block.settings.detail != blank -%}
              <div class="ido__ri-{{ section.id }} ido__ri3-{{ section.id }}">
                <p class="ido__reveal-detail-{{ section.id }}">{{ block.settings.detail }}</p>
              </div>
            {%- endif -%}

            <div class="ido__ri-{{ section.id }} ido__ri4-{{ section.id }}" style="margin-top: 14px;">
              <div class="ido__reveal-sep-{{ section.id }}"></div>
              <p class="ido__reveal-region-{{ section.id }}">{{ community }}</p>
              {%- if block.settings.link != blank and block.settings.link_label != blank -%}
                <a class="ido__reveal-link-{{ section.id }}" href="{{ block.settings.link }}">
                  {{ block.settings.link_label }}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              {%- endif -%}
            </div>

          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Ibérico — Denominaciones",
  "tag": "section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "do",
      "name": "Denominación de Origen",
      "settings": [
        {
          "type": "text",
          "id": "do_type",
          "label": "Tipo de protección",
          "default": "D.O.P.",
          "info": "Ej: D.O.P., I.G.P."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre (sin D.O.P./I.G.P.)",
          "default": "Jabugo"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Región — Comunidad (separados por —)",
          "default": "Huelva — Andalucía"
        },
        {
          "type": "text",
          "id": "municipality",
          "label": "Municipio de referencia",
          "default": "Jabugo, Huelva"
        },
        {
          "type": "textarea",
          "id": "flavor",
          "label": "Perfil de sabor",
          "default": "Aroma intenso y complejo, notas de frutos secos y hierbas de sierra. Grasa muy infiltrada con alto contenido en ácido oleico. Referente mundial del jamón ibérico de bellota."
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Detalle de curación (itálico, opcional)",
          "default": "Curación mínima de 24 meses en la sierra de Aracena, con altitud superior a 400 m."
        },
        {
          "type": "select",
          "id": "color",
          "label": "Color de la tarjeta",
          "options": [
            { "value": "navy",    "label": "Azul marino" },
            { "value": "cognac",  "label": "Cognac oscuro" },
            { "value": "umber",   "label": "Tierra oscura" },
            { "value": "forest",  "label": "Verde oscuro" }
          ],
          "default": "navy"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace a la colección (opcional)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto del enlace",
          "default": "Ver selección"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "El origen importa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título H2 (última palabra en cursiva dorada)",
      "default": "Denominaciones de Origen Protegidas"
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "Cuatro territorios, cuatro personalidades distintas. Cada Denominación de Origen garantiza el origen, la raza y el proceso de elaboración del jamón ibérico."
    }
  ],
  "presets": [
    {
      "name": "Ibérico — Denominaciones",
      "blocks": [
        {
          "type": "do",
          "settings": {
            "do_type": "D.O.P.",
            "name": "Jabugo",
            "region": "Huelva — Andalucía",
            "municipality": "Jabugo, Huelva",
            "flavor": "Aroma intenso y complejo, notas de frutos secos y hierbas de sierra. Grasa muy infiltrada con alto contenido en ácido oleico. Referente mundial del jamón ibérico de bellota.",
            "detail": "Curación mínima de 24 meses en la sierra de Aracena, con altitud superior a 400 m.",
            "color": "navy",
            "link_label": "Ver Jabugo"
          }
        },
        {
          "type": "do",
          "settings": {
            "do_type": "I.G.P.",
            "name": "Guijuelo",
            "region": "Salamanca — Castilla y León",
            "municipality": "Guijuelo, Salamanca",
            "flavor": "Sabor suave y delicado, curación lenta favorecida por el microclima de la sierra de Béjar. Menos salado que otras denominaciones, con textura de grasa más firme.",
            "detail": "A 1.000 m de altitud, el frío y la baja humedad condicionan una curación única.",
            "color": "cognac",
            "link_label": "Ver Guijuelo"
          }
