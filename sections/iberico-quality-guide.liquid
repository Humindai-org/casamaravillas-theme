<style>
  .iqg-{{ section.id }} {
    background: var(--cm-off);
    padding: 96px 24px;
    border-bottom: 1px solid var(--cm-border);
    scroll-margin-top: 56px;
  }

  .iqg__inner-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .iqg__header-{{ section.id }} {
    text-align: center;
    margin-bottom: 56px;
  }

  .iqg__eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--cm-font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 18px;
  }

  .iqg__heading-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .iqg__heading-{{ section.id }} em {
    font-style: italic;
    color: var(--cm-gold);
  }

  .iqg__subhead-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 14px;
    font-weight: 300;
    color: var(--cm-text-mid);
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Grid 2×2 ── */
  .iqg__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: var(--cm-border);
    border: 1px solid var(--cm-border);
  }

  /* ── Card ── */
  .iqg__card-{{ section.id }} {
    background: var(--cm-white);
    padding: 36px 40px 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 3px solid transparent;
    transition: transform 0.28s ease, box-shadow 0.28s ease;
    position: relative;
  }

  .iqg__card-{{ section.id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(0,41,75,0.07), 0 3px 10px rgba(0,41,75,0.04);
    z-index: 2;
  }

  /* ── Accent colors ── */
  .iqg__card--gold-{{ section.id }}       { border-top-color: var(--cm-gold); }
  .iqg__card--terracotta-{{ section.id }} { border-top-color: #C05A38; }
  .iqg__card--burgundy-{{ section.id }}   { border-top-color: #7A1F3C; }
  .iqg__card--olive-{{ section.id }}      { border-top-color: #5A6B40; }
  .iqg__card--slate-{{ section.id }}      { border-top-color: #4A5B6B; }

  /* ── Level dots ── */
  .iqg__level-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 20px;
  }

  .iqg__dot-{{ section.id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cm-border);
    flex-shrink: 0;
  }

  .iqg__card--gold-{{ section.id }}       .iqg__dot-{{ section.id }}.is-filled { background: var(--cm-gold); }
  .iqg__card--terracotta-{{ section.id }} .iqg__dot-{{ section.id }}.is-filled { background: #C05A38; }
  .iqg__card--burgundy-{{ section.id }}   .iqg__dot-{{ section.id }}.is-filled { background: #7A1F3C; }
  .iqg__card--olive-{{ section.id }}      .iqg__dot-{{ section.id }}.is-filled { background: #5A6B40; }
  .iqg__card--slate-{{ section.id }}      .iqg__dot-{{ section.id }}.is-filled { background: #4A5B6B; }

  .iqg__level-label-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cm-text-light);
    margin-left: 6px;
  }

  /* ── Tag ── */
  .iqg__tag-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 7.5px;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--cm-text-light);
    margin-bottom: 10px;
  }

  /* ── Card name ── */
  .iqg__name-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(19px, 2.2vw, 26px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  /* ── Description ── */
  .iqg__desc-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: 13.5px;
    font-weight: 300;
    color: var(--cm-text-mid);
    line-height: 1.75;
    flex: 1;
  }

  /* ── Tablet ── */
  @media (max-width: 1023px) {
    .iqg__card-{{ section.id }} { padding: 28px 28px 32px; }
  }

  /* ── Mobile: single column ── */
  @media (max-width: 767px) {
    .iqg-{{ section.id }} { padding: 64px 24px; }
    .iqg__grid-{{ section.id }} { grid-template-columns: 1fr; }
    .iqg__card-{{ section.id }} { padding: 24px 24px 28px; }
    .iqg__name-{{ section.id }} { font-size: 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .iqg__card-{{ section.id }} { transition: none; }
  }
</style>

<section class="iqg-{{ section.id }}" id="tipos-de-jamon">
  <div class="iqg__inner-{{ section.id }}">

    <header class="iqg__header-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="iqg__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="iqg__heading-{{ section.id }}">
        {%- assign h_words = section.settings.heading | default: 'Los 4 Tipos de Jamón Ibérico' | split: ' ' -%}
        {%- for word in h_words -%}
          {%- if forloop.last -%}<em>{{ word }}</em>{%- else -%}{{ word }} {%- endif -%}
        {%- endfor -%}
      </h2>
      {%- if section.settings.subhead != blank -%}
        <p class="iqg__subhead-{{ section.id }}">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </header>

    <div class="iqg__grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign color = block.settings.color | default: 'slate' -%}
        {%- assign level = block.settings.level | default: 2 -%}

        <article
          class="iqg__card-{{ section.id }} iqg__card--{{ color }}-{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="iqg__level-{{ section.id }}" aria-label="Nivel de calidad: {{ level }} de 4">
            {%- for i in (1..4) -%}
              <span class="iqg__dot-{{ section.id }}{% if i <= level %} is-filled{% endif %}" aria-hidden="true"></span>
            {%- endfor -%}
            <span class="iqg__level-label-{{ section.id }}">{{ block.settings.level_label | default: 'Calidad' }}</span>
          </div>

          {%- if block.settings.tag != blank -%}
            <p class="iqg__tag-{{ section.id }}">{{ block.settings.tag }}</p>
          {%- endif -%}

          <h3 class="iqg__name-{{ section.id }}">{{ block.settings.name | default: 'Tipo ibérico' }}</h3>

          {%- if block.settings.description != blank -%}
            <p class="iqg__desc-{{ section.id }}">{{ block.settings.description }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Guía Ibérico — Los 4 Tipos",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "tier",
      "name": "Tipo de ibérico",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Etiqueta pequeña",
          "default": "Categoría"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre del tipo",
          "default": "Bellota 100% Ibérico"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Descripción del tipo de ibérico."
        },
        {
          "type": "range",
          "id": "level",
          "label": "Nivel de calidad (1–4)",
          "min": 1,
          "max": 4,
          "step": 1,
          "default": 4
        },
        {
          "type": "text",
          "id": "level_label",
          "label": "Etiqueta del nivel",
          "default": "Calidad máxima"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Color de acento",
          "options": [
            { "value": "gold",       "label": "Dorado" },
            { "value": "terracotta", "label": "Terracota" },
            { "value": "burgundy",   "label": "Burdeos" },
            { "value": "olive",      "label": "Oliva" },
            { "value": "slate",      "label": "Pizarra" }
          ],
          "default": "gold"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "La clasificación oficial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título H2",
      "default": "Los 4 Tipos de Jamón Ibérico"
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Subtítulo",
      "default": "El Real Decreto 4/2014 establece cuatro categorías según la raza del animal y su alimentación durante la montanera."
    }
  ],
  "presets": [
    {
      "name": "Guía Ibérico — Los 4 Tipos",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "tag": "La cima del ibérico",
            "name": "Bellota 100% Ibérico",
            "description": "Cerdo 100% de raza ibérica criado en libertad en la dehesa. Alimentado exclusivamente con bellotas y hierbas naturales durante la montanera (octubre–febrero). Es el jamón de mayor calidad organoléptica, con grasa infiltrada en el músculo que aporta el característico sabor a fruto seco.",
            "level": 4,
            "level_label": "Calidad máxima",
            "color": "gold"
          }
        },
        {
          "type": "tier",
          "settings": {
            "tag": "Alta calidad",
            "name": "Bellota Ibérico",
            "description": "Cerdo ibérico (con cruce permitido de hasta 50% de raza Duroc) alimentado con bellotas en la dehesa durante la montanera. Excelente calidad, con la profundidad de sabor característica de la alimentación en campo. La opción premium accesible.",
            "level": 3,
            "level_label": "Alta calidad",
            "color": "terracotta"
          }
        },
        {
          "type": "tier",
          "settings": {
            "tag": "Calidad media-alta",
            "name": "Cebo de Campo Ibérico",
            "description": "Cerdo ibérico criado en extensivo con acceso a pastos naturales, complementado con piensos. No accede a la montanera de bellota, pero el ejercicio en campo libre le aporta una infiltración grasa mayor que el cebo estabulado.",
            "level": 2,
            "level_label": "Calidad media-alta",
            "color": "burgundy"
          }
        },
        {
          "type": "tier",
          "settings": {
            "tag": "Calidad estándar",
            "name": "Cebo Ibérico",
            "description": "Cerdo ibérico criado en granja intensiva y alimentado con piensos compuestos. Conserva la genética ibérica, que le aporta cierta infiltración grasa frente al cerdo blanco, pero sin los matices de la montanera ni el ejercicio en campo.",
            "level": 1,
            "level_label": "Calidad estándar",
            "color": "slate"
          }
        }
      ]
    }
  ]
}
{% endschema %}
