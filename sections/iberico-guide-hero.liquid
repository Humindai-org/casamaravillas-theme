<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&display=swap');

.igh-{{ section.id }} {
  position: relative;
  min-height: 90vh;
  display: flex;
  align-items: center;
  background-color: #001A30;
  overflow: hidden;
}


/* overlay fino */
.igh__overlay-{{ section.id }} {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(0,26,48,0.55) 0%, rgba(0,26,48,0.25) 45%, transparent 75%),
    linear-gradient(to bottom, rgba(0,26,48,0.2) 0%, transparent 40%, rgba(0,26,48,0.35) 100%);
}

/* contenido */
.igh__inner-{{ section.id }} {
  position: relative;
  z-index: 2;
  max-width: 1200px;
  padding: 80px;
}

/* TITULO */
.igh__title-{{ section.id }} {
  font-family: 'Cormorant Garamond', serif;
  line-height: 0.9;
}

.igh__t1-{{ section.id }} {
  display:block;
  font-size: clamp(60px,7vw,110px);
  color:#fff;
  font-weight:500;
}

.igh__t2-{{ section.id }} {
  display:block;
  font-size: clamp(28px,3vw,48px);
  font-style: italic;
  color:#C49A3C;
  margin-left:10px;
}

.igh__t3-{{ section.id }} {
  display:block;
  font-size: clamp(80px,10vw,150px);
  color:#fff;
  font-weight:500;
}

/* subtitulo */
.igh__sub-{{ section.id }} {
  font-family:'Cormorant Garamond',serif;
  font-size:18px;
  color:rgba(255,255,255,0.75);
  margin-top:30px;
}

.igh__sub em {
  display:block;
  font-style:italic;
  color:#fff;
}

/* boton */
.igh__cta-{{ section.id }} {
  margin-top:40px;
  display:inline-block;
  padding:14px 28px;
  border:1px solid rgba(255,255,255,0.4);
  font-size:12px;
  letter-spacing:0.2em;
  text-transform:uppercase;
  color:#fff;
  text-decoration:none;
}

.igh__cta-{{ section.id }}:hover {
  border-color:#C49A3C;
  color:#C49A3C;
}

/* ===== SECCION ARTE ===== */

.igh__bar-{{ section.id }} {
  background:#001A30;
  padding:80px;
}

.igh__bar-inner-{{ section.id }} {
  display:grid;
  grid-template-columns: 350px 1fr;
  gap:60px;
}

.igh__bar-title-{{ section.id }} {
  font-family:'Cormorant Garamond',serif;
  font-size:48px;
  color:#fff;
}

.igh__bar-title-{{ section.id }} em {
  display:block;
  color:#C49A3C;
  font-style:italic;
}

.igh__bar-sub-{{ section.id }} {
  margin-top:20px;
  font-size:16px;
  color:rgba(255,255,255,0.6);
}

.igh__feats-{{ section.id }} {
  display:grid;
  grid-template-columns: repeat(4,1fr);
}

/* item */
.igh__feat-{{ section.id }} {
  text-align:center;
  padding:0 20px;
  border-left:1px solid rgba(255,255,255,0.08);
}

/* ICONOS EXACTOS */
.igh__feat-icon-{{ section.id }} svg {
  width:44px;
  height:44px;
  stroke:#C49A3C;
  stroke-width:0.8;
  fill:none;
  margin-bottom:15px;
}

/* label */
.igh__feat-label-{{ section.id }} {
  font-size:11px;
  letter-spacing:0.25em;
  color:#C49A3C;
  margin-bottom:10px;
}

/* texto */
.igh__feat-desc-{{ section.id }} {
  font-size:14px;
  color:rgba(255,255,255,0.6);
}
</style>

<section class="igh-{{ section.id }}">

{% if section.settings.image %}
<style>
  .igh-{{ section.id }} {
    background-image: url({{ section.settings.image | image_url: width: 2000 }});
    background-size: cover;
    background-position: 70% center;
    background-repeat: no-repeat;
  }
</style>
{% endif %}

<div class="igh__overlay-{{ section.id }}"></div>

<div class="igh__inner-{{ section.id }}">

<h1 class="igh__title-{{ section.id }}">
<span class="igh__t1-{{ section.id }}">LA GUÍA</span>
<span class="igh__t2-{{ section.id }}">del</span>
<span class="igh__t3-{{ section.id }}">IBÉRICO</span>
</h1>

<p class="igh__sub-{{ section.id }}">
Todo lo que necesitas saber sobre
<em>el auténtico lujo español.</em>
</p>

<a href="#" class="igh__cta-{{ section.id }}">EXPLORAR LA GUÍA →</a>

</div>
</section>

<div class="igh__bar-{{ section.id }}">
<div class="igh__bar-inner-{{ section.id }}">

<div>
<h2 class="igh__bar-title-{{ section.id }}">
EL ARTE DE LO
<em>Excepcional</em>
</h2>

<p class="igh__bar-sub-{{ section.id }}">
Tradición, naturaleza y tiempo se unen para crear un producto único en el mundo.
</p>
</div>

<div class="igh__feats-{{ section.id }}">

<div class="igh__feat-{{ section.id }}">
<div class="igh__feat-icon-{{ section.id }}">
<svg viewBox="0 0 24 24">
<path d="M12 20V10M12 10C10 8 8 7 6 7C6 10 9 12 12 10ZM12 10C14 8 16 7 18 7C18 10 15 12 12 10Z"/>
</svg>
</div>
<div class="igh__feat-label-{{ section.id }}">RAZA</div>
<div class="igh__feat-desc-{{ section.id }}">Cerdos ibéricos puro de bellota.</div>
</div>

<div class="igh__feat-{{ section.id }}">
<div class="igh__feat-icon-{{ section.id }}">
<svg viewBox="0 0 24 24">
<path d="M12 20V12M12 12C10 9 7 8 5 8C5 12 9 14 12 12ZM12 12C14 9 17 8 19 8C19 12 15 14 12 12Z"/>
</svg>
</div>
<div class="igh__feat-label-{{ section.id }}">ALIMENTACIÓN</div>
<div class="igh__feat-desc-{{ section.id }}">Bellota, pastos naturales y recursos del campo.</div>
</div>

<div class="igh__feat-{{ section.id }}">
<div class="igh__feat-icon-{{ section.id }}">
<svg viewBox="0 0 24 24">
<circle cx="12" cy="12" r="8"/>
<path d="M12 8V12L15 14"/>
</svg>
</div>
<div class="igh__feat-label-{{ section.id }}">TIEMPO</div>
<div class="igh__feat-desc-{{ section.id }}">Curación lenta y natural para un sabor inigualable.</div>
</div>

<div class="igh__feat-{{ section.id }}">
<div class="igh__feat-icon-{{ section.id }}">
<svg viewBox="0 0 24 24">
<path d="M7 20C7 15 10 10 12 8C14 10 17 15 17 20"/>
<path d="M9 14H15M9 17H15"/>
</svg>
</div>
<div class="igh__feat-label-{{ section.id }}">EXPERIENCIA</div>
<div class="igh__feat-desc-{{ section.id }}">Sabor, aroma y textura que cuentan historias.</div>
</div>

</div>
</div>
</div>

{% schema %}
{
  "name": "Iberico Guide Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero background image"
    }
  ],
  "presets": [
    {
      "name": "Iberico Guide Hero"
    }
  ]
}
{% endschema %}