<style>
  .igh-{{ section.id }} {
    position: relative;
    padding: 88px 24px 76px;
    background: var(--cm-navy);
    overflow: hidden;
  }

  .igh__bg-{{ section.id }} {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.22;
    filter: saturate(0.4) brightness(0.6);
    transform: scale(1.04);
  }

  .igh__grain-{{ section.id }} {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 2;
  }

  .igh__fade-{{ section.id }} {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to top, rgba(0,41,75,0.4), transparent);
    z-index: 2;
    pointer-events: none;
  }

  .igh__inner-{{ section.id }} {
    position: relative;
    z-index: 3;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .igh__breadcrumb-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
    font-family: var(--cm-font-sans);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: rgba(250,246,239,0.38);
  }

  .igh__breadcrumb-{{ section.id }} a {
    color: rgba(250,246,239,0.38);
    transition: color 0.2s;
  }

  .igh__breadcrumb-{{ section.id }} a:hover {
    color: var(--cm-gold);
  }

  .igh__breadcrumb-{{ section.id }} a:focus-visible {
    outline: 1px solid var(--cm-gold);
    outline-offset: 2px;
  }

  .igh__breadcrumb-sep-{{ section.id }} {
    font-size: 9px;
    opacity: 0.4;
  }

  .igh__eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--cm-font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 24px;
  }

  .igh__rule-{{ section.id }} {
    width: 40px;
    height: 1px;
    background: rgba(196,151,58,0.4);
    margin: 0 auto 28px;
  }

  .igh__title-{{ section.id }} {
    font-family: var(--cm-font-serif);
    font-size: clamp(30px, 4.8vw, 60px);
    font-weight: 400;
    color: var(--cm-off);
    line-height: 1.15;
    margin-bottom: 22px;
  }

  .igh__title-{{ section.id }} em {
    font-style: italic;
    color: var(--cm-gold);
  }

  .igh__subtitle-{{ section.id }} {
    font-family: var(--cm-font-sans);
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 300;
    color: rgba(250,246,239,0.58);
    letter-spacing: 0.03em;
    line-height: 1.85;
    max-width: 540px;
    margin: 0 auto 44px;
  }

  .igh__cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--cm-font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cm-gold);
    border: 1px solid rgba(196,151,58,0.38);
    padding: 14px 30px;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .igh__cta-{{ section.id }}:hover {
    background: rgba(196,151,58,0.08);
    border-color: var(--cm-gold);
    color: var(--cm-gold-h);
  }

  .igh__cta-{{ section.id }}:focus-visible {
    outline: 2px solid var(--cm-gold);
    outline-offset: 3px;
  }

  .igh__arrow-{{ section.id }} {
    width: 13px;
    height: 13px;
    transition: transform 0.25s ease;
  }

  .igh__cta-{{ section.id }}:hover .igh__arrow-{{ section.id }} {
    transform: translateY(3px);
  }

  @media (max-width: 767px) {
    .igh-{{ section.id }} { padding: 60px 24px 52px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .igh__cta-{{ section.id }},
    .igh__cta-{{ section.id }} * { transition: none; }
  }
</style>

<section
  class="igh-{{ section.id }}"
  aria-label="{{ section.settings.eyebrow | default: 'Guía del Ibérico' }}"
>
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 1800
      | image_tag:
          class: 'igh__bg-' | append: section.id,
          loading: 'eager',
          fetchpriority: 'high',
          alt: ''
    }}
  {%- endif -%}

  <div class="igh__grain-{{ section.id }}" aria-hidden="true"></div>
  <div class="igh__fade-{{ section.id }}"  aria-hidden="true"></div>

  <div class="igh__inner-{{ section.id }}">
    <nav class="igh__breadcrumb-{{ section.id }}" aria-label="Ruta de navegación">
      <a href="{{ routes.root_url }}">Inicio</a>
      <span class="igh__breadcrumb-sep-{{ section.id }}" aria-hidden="true">›</span>
      <span aria-current="page">{{ section.settings.breadcrumb_label | default: 'Guía del Ibérico' }}</span>
    </nav>

    {%- if section.settings.eyebrow != blank -%}
      <span class="igh__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <div class="igh__rule-{{ section.id }}" aria-hidden="true"></div>

    <h1 class="igh__title-{{ section.id }}">
      {%- assign title_words = section.settings.heading | default: 'Guía del Jamón Ibérico' | split: ' ' -%}
      {%- for word in title_words -%}
        {%- if forloop.last -%}<em>{{ word }}</em>{%- else -%}{{ word }} {%- endif -%}
      {%- endfor -%}
    </h1>

    {%- if section.settings.subtitle != blank -%}
      <p class="igh__subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_anchor != blank -%}
      <a
        class="igh__cta-{{ section.id }}"
        href="#{{ section.settings.cta_anchor }}"
      >
        {{ section.settings.cta_label }}
        <svg class="igh__arrow-{{ section.id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <polyline points="19 12 12 19 5 12"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Guía Ibérico — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo (opcional)"
    },
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Texto del breadcrumb (último nivel)",
      "default": "Guía del Ibérico"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Mundo ibérico"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título H1",
      "info": "La última palabra se muestra en cursiva dorada.",
      "default": "Guía del Jamón Ibérico"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Todo lo que necesitas saber para elegir, cortar y disfrutar el mejor ibérico — tipos, denominaciones y consejos de conservación."
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Explorar la guía"
    },
    {
      "type": "text",
      "id": "cta_anchor",
      "label": "Anchor ID destino (sin #)",
      "default": "iberico-vs-serrano",
      "info": "El ID de la sección a la que desplaza el botón."
    }
  ],
  "presets": [
    {
      "name": "Guía Ibérico — Hero"
    }
  ]
}
{% endschema %}
