<style>
  .story-teaser {
    position: relative;
    overflow: hidden;
    background: var(--cm-navy);
    min-height: 420px;
    display: flex;
    align-items: center;
    border-top: 1px solid rgba(196, 151, 58, 0.25);
    border-bottom: 1px solid rgba(196, 151, 58, 0.25);
  }

  .story-teaser__bg {
    position: absolute;
    inset: 0;
  }

  .story-teaser__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
    filter: saturate(0) brightness(0.7);
  }

  .story-teaser__numeral {
    position: absolute;
    right: 7%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--cm-font-serif);
    font-size: clamp(160px, 22vw, 280px);
    font-weight: 400;
    font-style: italic;
    color: var(--cm-gold);
    opacity: 0.06;
    line-height: 0.85;
    user-select: none;
    pointer-events: none;
    letter-spacing: -0.02em;
  }

  .story-teaser__inner {
    position: relative;
    z-index: 1;
    max-width: 1160px;
    width: 100%;
    margin: 0 auto;
    padding: 96px 80px;
  }

  .story-teaser__eyebrow {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--cm-gold);
    font-weight: 500;
    margin-bottom: 20px;
    font-family: var(--cm-font-sans);
  }

  .story-teaser__title {
    font-family: var(--cm-font-serif);
    font-size: clamp(30px, 4vw, 58px);
    font-weight: 400;
    color: white;
    line-height: 1.12;
    margin-bottom: 24px;
    max-width: 540px;
  }

  .story-teaser__title em {
    font-style: italic;
    color: var(--cm-gold);
  }

  .story-teaser__body {
    font-family: var(--cm-font-sans);
    font-size: 14.5px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.52);
    margin-bottom: 36px;
    max-width: 460px;
  }

  .story-teaser__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--cm-font-sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--cm-gold);
    text-decoration: none;
    transition: gap 0.25s ease;
  }

  .story-teaser__cta:hover { gap: 16px; }

  .story-teaser__cta svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .story-teaser__cta:hover svg { transform: translateX(4px); }

  .story-teaser__cta:focus-visible {
    outline: 2px solid var(--cm-gold);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (max-width: 1023px) {
    .story-teaser__inner { padding: 80px 48px; }
  }

  @media (max-width: 767px) {
    .story-teaser { min-height: 360px; }
    .story-teaser__inner { padding: 56px 24px; }
    .story-teaser__numeral { display: none; }
  }
</style>

<section class="story-teaser">
  <div class="story-teaser__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag:
        loading: 'lazy',
        alt: '',
        aria_hidden: 'true'
      }}
    {%- endif -%}
  </div>

  <span class="story-teaser__numeral" aria-hidden="true">III</span>

  <div class="story-teaser__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="story-teaser__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h2 class="story-teaser__title">{{ section.settings.title }}</h2>

    {%- if section.settings.body != blank -%}
      <p class="story-teaser__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url | default: '/pages/sobre-nosotros' }}" class="story-teaser__cta">
        {{ section.settings.cta_label }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Mini bloque historia",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo (opcional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Nuestra historia"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Una historia de <em>tradición</em></p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Descripción",
      "default": "Tres generaciones dedicadas al ibérico. Descubre quiénes somos y cómo seleccionamos cada pieza para mantener la calidad de siempre."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del enlace",
      "default": "Conoce nuestra historia"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace"
    }
  ],
  "presets": [
    {
      "name": "Mini bloque historia"
    }
  ]
}
{% endschema %}
