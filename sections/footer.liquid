          <path d="M375 122C405 143 428 174 438 210H312C322 174 345 143 375 122ZM375 350C345 329 322 298 312 262H438C428 298 405 329 375 350Z" fill="#FF5F00"/>
        </svg>
      </span>
      <!-- PayPal -->
      <span class="site-footer__payment-logo" title="PayPal">
        <svg height="24" viewBox="0 0 750 471" xmlns="http://www.w3.org/2000/svg">
          <rect width="750" height="471" rx="40" fill="#F7F7F7" stroke="#E0E0E0" stroke-width="2"/>
          <path d="M260 155H340C383 155 405 177 399 215C392 259 361 282 318 282H298L283 350H230L260 155Z" fill="#253B80"/>
