          <path d="M283 282H303L288 350H268L283 282Z" fill="#222D65"/>
        </svg>
      </span>
      <!-- Bizum -->
      <span class="site-footer__payment-logo" title="Bizum">
        <svg height="24" viewBox="0 0 750 471" xmlns="http://www.w3.org/2000/svg">
          <rect width="750" height="471" rx="40" fill="#00ADEF"/>
          <text x="375" y="290" font-family="Arial, sans-serif" font-weight="700" font-size="130" fill="white" text-anchor="middle" letter-spacing="2">Bizum</text>
        </svg>
      </span>
      <!-- Apple Pay -->
      <span class="site-footer__payment-logo" title="Apple Pay">
        <svg height="24" viewBox="0 0 750 471" xmlns="http://www.w3.org/2000/svg">
          <rect width="750" height="471" rx="40" fill="#000000"/>
          <path d="M203 160C211 150 216 137 215 124C203 125 188 132 180 142C172 151 166 165 167 177C180 178 194 171 203 160Z" fill="white"/>
          <path d="M214 179C196 178 181 189 172 189C163 189 150 180 135 180C113 181 92 194 81 215C58 257 76 320 98 354C109 371 122 390 140 389C157 388 164 378 183 378C202 378 208 389 226 389C244 388 256 371 267 354C279 336 284 318 285 317C284 317 251 304 251 267C250 235 276 220 277 219C261 196 234 178 214 179Z" fill="white"/>
          <path d="M380 144H417C443 144 459 161 459 188C459 215 442 233 415 233H397V271H380V144ZM397 219H412C429 219 441 208 441 188C441 168 430 158 413 158H397V219Z" fill="white"/>
          <path d="M462 249C462 233 475 224 498 222L524 221V214C524 204 517 198 505 198C495 198 487 203 485 211H469C471 193 488 181 506 181C527 181 541 193 541 212V271H524V256H524C519 265 510 272 496 272C477 272 462 262 462 249ZM524 240V233L501 234C490 235 480 240 480 249C480 258 488 263 498 263C513 263 524 253 524 240Z" fill="white"/>
          <path d="M553 305V292C557 293 561 294 565 294C577 294 584 289 588 277L591 268L557 183H575L599 258H600L624 183H641L606 278C597 304 585 314 566 314C562 314 557 313 553 305Z" fill="white"/>
        </svg>
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (versión oscura, para fondo claro)"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline / descripción breve",
      "default": "Productos ibéricos artesanales desde Alicante. Tres generaciones de sabor auténtico."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    }
  ]
}
{% endschema %}
