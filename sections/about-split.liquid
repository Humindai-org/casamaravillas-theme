<style>
  .about-editorial {
    display: grid;
    grid-template-columns: 0.32fr 1fr;
    min-height: 480px;
    background: var(--cm-white);
    border-top: 1px solid var(--cm-border);
    border-bottom: 1px solid var(--cm-border);
  }

  .about-editorial__numeral-col {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 64px 48px 64px 40px;
    border-right: 1px solid var(--cm-border);
  }

  .about-editorial__numeral {
    font-family: var(--cm-font-serif);
    font-size: clamp(100px, 14vw, 160px);
    font-weight: 400;
    font-style: italic;
    color: var(--cm-gold);
    line-height: 0.85;
    user-select: none;
    opacity: 0.9;
  }

  .about-editorial__content-col {
    padding: 72px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-editorial__eyebrow {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--cm-gold);
    font-weight: 500;
    margin-bottom: 20px;
    font-family: var(--cm-font-sans);
  }

  .about-editorial__title {
    font-family: var(--cm-font-serif);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 400;
    color: var(--cm-navy);
    line-height: 1.2;
    margin-bottom: 28px;
  }

  .about-editorial__title em { font-style: italic; }

  .about-editorial__body {
    font-size: 14.5px;
    line-height: 1.85;
    color: var(--cm-text-mid);
    margin-bottom: 44px;
    max-width: 520px;
    font-family: var(--cm-font-sans);
  }

  /* Stats row — 2 celdas navy */
  .about-editorial__stats {
    display: grid;
    grid-template-columns: repeat(2, auto);
    gap: 0;
    margin-bottom: 40px;
    width: fit-content;
  }

  .about-editorial__stat {
    background: var(--cm-navy);
    padding: 24px 36px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .about-editorial__stat:last-child { border-right: none; }

  .about-editorial__stat-num {
    font-family: var(--cm-font-serif);
    font-size: 38px;
    font-weight: 400;
    font-style: italic;
    color: var(--cm-gold);
    line-height: 1;
    display: block;
  }

  .about-editorial__stat-label {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 8px;
    line-height: 1.4;
    font-family: var(--cm-font-sans);
    display: block;
  }

  @media (max-width: 1023px) {
    .about-editorial__content-col { padding: 56px 48px; }
    .about-editorial__numeral-col { padding: 48px 32px 48px 32px; }
  }

  @media (max-width: 767px) {
    .about-editorial {
      grid-template-columns: 1fr;
    }
    .about-editorial__numeral-col {
      justify-content: flex-start;
      padding: 48px 24px 0;
      border-right: none;
    }
    .about-editorial__numeral { font-size: clamp(80px, 22vw, 120px); }
    .about-editorial__content-col {
      padding: 32px 24px 48px;
    }
    .about-editorial__stats { grid-template-columns: 1fr 1fr; width: 100%; }
    .about-editorial__stat { padding: 20px 24px; }
  }
</style>

<section class="about-editorial">

  <!-- Numeral decorativo -->
  <div class="about-editorial__numeral-col">
    <span class="about-editorial__numeral" aria-hidden="true">III</span>
  </div>

  <!-- Contenido -->
  <div class="about-editorial__content-col">

    {%- if section.settings.eyebrow != blank -%}
      <p class="about-editorial__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h2 class="about-editorial__title">{{ section.settings.title | default: 'Una historia de <em>tradición</em>' }}</h2>

    {%- if section.settings.body != blank -%}
      <p class="about-editorial__body">{{ section.settings.body }}</p>
    {%- endif -%}

    <!-- Stats navy -->
    {%- if section.blocks.size > 0 -%}
      <div class="about-editorial__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="about-editorial__stat" {{ block.shopify_attributes }}>
              <span class="about-editorial__stat-num">{{ block.settings.number }}</span>
              <span class="about-editorial__stat-label">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url | default: '/pages/sobre-nosotros' }}" class="cm-link-arrow">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Historia editorial",
  "tag": "section",
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Número",
          "default": "3"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Generaciones"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "Nuestra historia"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Una historia de <em>tradición</em></p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Descripción",
      "default": "Tres generaciones dedicadas a seleccionar los mejores productos ibéricos de la dehesa española. Una tradición familiar que hoy llega a tu mesa con la misma pasión artesanal de siempre."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del enlace",
      "default": "Conoce nuestra historia"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace"
    }
  ],
  "presets": [
    {
      "name": "Historia editorial",
      "blocks": [
        { "type": "stat", "settings": { "number": "3", "label": "Generaciones" } },
        { "type": "stat", "settings": { "number": "100%", "label": "Ibérico puro" } }
      ]
    }
  ]
}
{% endschema %}
