<style>
  /* ── Shared elements ── */
  .nve__eyebrow {
    font-family: var(--cm-font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--cm-gold);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .nve__eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--cm-gold);
    flex-shrink: 0;
  }

  .nve__headline {
    font-family: var(--cm-font-serif);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 32px;
  }

  .nve__body {
    font-family: var(--cm-font-sans);
    font-size: clamp(13.5px, 1.4vw, 16px);
    line-height: 1.9;
    font-weight: 300;
  }

  .nve__body p { margin-bottom: 1.4em; }
  .nve__body p:last-child { margin-bottom: 0; }

  .sr-w { display: inline-block; }

  /* ── Grain helper ── */
  .nve-grain::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 2;
  }

  /* ─────────────────────────────────────────────────
     LAYOUT: text-full
     Full editorial text. Headline left / body right.
     ───────────────────────────────────────────────── */
  .nve__text-full {
    background: var(--cm-navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(100px, 12vw, 160px) clamp(48px, 10vw, 140px);
  }

  .nve__text-full-inner {
    width: 100%;
    max-width: 1200px;
  }

  .nve__text-full .nve__tf-grid {
    display: grid;
    grid-template-columns: 1fr 0.75fr;
    gap: clamp(48px, 6vw, 100px);
    align-items: start;
  }

  .nve__text-full .nve__headline {
    font-size: clamp(48px, 6.5vw, 96px);
    color: var(--cm-off);
    margin-bottom: 0;
  }

  .nve__text-full .nve__body {
    color: rgba(250,246,239,0.72);
    padding-top: 12px;
  }

  /* ─────────────────────────────────────────────────
     LAYOUT: split
     Image 55% left / text 45% right.
     ───────────────────────────────────────────────── */
  .nve__split {
    display: grid;
    grid-template-columns: 55% 45%;
    min-height: 100vh;
    overflow: hidden;
  }

  .nve__split__img {
    position: relative;
    overflow: hidden;
  }

  .nve__split__img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nve__split__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 2;
  }

  .nve__split__img-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, #001828 0%, #002a40 60%, #001020 100%);
  }

  .nve__split__text {
    background: var(--cm-off);
    display: flex;
    align-items: center;
    padding: clamp(64px, 8vw, 120px) clamp(40px, 5vw, 80px);
  }

  .nve__split__text-inner {
    max-width: 420px;
  }

  .nve__split .nve__headline {
    font-size: clamp(30px, 3.2vw, 50px);
    color: var(--cm-navy);
  }

  .nve__split .nve__body {
    color: var(--cm-text-mid);
  }

  /* ─────────────────────────────────────────────────
     LAYOUT: cinematic
     Full-bleed image + floating navy panel bottom-right.
     ───────────────────────────────────────────────── */
  .nve__cinematic {
    position: relative;
    height: 90vh;
    min-height: 600px;
    overflow: hidden;
  }

  .nve__cinematic__img-wrap {
    position: absolute;
    inset: 0;
  }

  .nve__cinematic__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nve__cinematic__img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 2;
  }

  .nve__cinematic__img-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, #001828 0%, #002a40 60%, #001020 100%);
  }

  .nve__cinematic__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(0,41,75,0.45) 100%);
    z-index: 3;
    pointer-events: none;
  }

  .nve__cinematic__panel {
    position: absolute;
    bottom: 0;
    right: 0;
    width: clamp(300px, 40%, 560px);
    background: var(--cm-navy);
    padding: clamp(40px, 5vw, 64px) clamp(36px, 4vw, 56px);
    z-index: 4;
  }

  .nve__cinematic .nve__headline {
    font-size: clamp(26px, 2.8vw, 44px);
    color: var(--cm-off);
  }

  .nve__cinematic .nve__body {
    color: rgba(250,246,239,0.72);
    font-size: clamp(13px, 1.3vw, 15px);
  }

  /* ─────────────────────────────────────────────────
     LAYOUT: centered
     Centered editorial text, cream background.
     ───────────────────────────────────────────────── */
  .nve__centered {
    background: var(--cm-off);
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(100px, 12vw, 160px) clamp(24px, 8vw, 120px);
  }

  .nve__centered__inner {
    max-width: 840px;
  }

  .nve__centered .nve__eyebrow {
    justify-content: center;
  }

  .nve__centered .nve__headline {
    font-size: clamp(40px, 5.5vw, 80px);
    color: var(--cm-navy);
    max-width: 720px;
    margin: 0 auto 36px;
  }

  .nve__centered .nve__body {
    color: var(--cm-text-mid);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .nve__text-full {
      padding: 80px 24px;
      min-height: auto;
    }

    .nve__text-full .nve__tf-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .nve__text-full .nve__headline {
      font-size: clamp(40px, 9vw, 56px);
    }

    .nve__split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .nve__split__img {
      height: 65vw;
      min-height: 280px;
      position: relative;
    }

    .nve__split__img img {
      position: absolute;
    }

    .nve__split__text {
      padding: 48px 24px;
    }

    .nve__split__text-inner {
      max-width: 100%;
    }

    .nve__cinematic {
      height: auto;
      min-height: auto;
    }

    .nve__cinematic__img-wrap {
      position: relative;
      height: 62vw;
      min-height: 280px;
    }

    .nve__cinematic__img-wrap img {
      position: absolute;
    }

    .nve__cinematic__overlay {
      display: none;
    }

    .nve__cinematic__panel {
      position: relative;
      width: 100%;
      padding: 48px 24px;
    }

    .nve__centered {
      padding: 80px 24px;
      min-height: auto;
    }

    .nve__centered .nve__headline {
      font-size: clamp(36px, 8vw, 52px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sr-w { opacity: 1 !important; filter: none !important; }
  }
</style>

<section
  class="nve"
  id="nve-{{ section.id }}"
  aria-label="{{ section.settings.aria_label | default: 'Nuestros valores' }}"
>

  {%- for block in section.blocks -%}

    {%- if block.type == 'text-full' -%}
    {%- comment -%} ── Layout: editorial text full width ── {%- endcomment -%}
    <div class="nve__text-full" data-sr-block {{ block.shopify_attributes }}>
      <div class="nve__text-full-inner">
        {%- if block.settings.value_name != blank -%}
          <p class="nve__eyebrow">{{ block.settings.value_name }}</p>
        {%- endif -%}
        <div class="nve__tf-grid">
          {%- if block.settings.headline != blank -%}
            <h2 class="nve__headline" data-sr-h>{{ block.settings.headline }}</h2>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <div class="nve__body">{{ block.settings.body }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- elsif block.type == 'split' -%}
    {%- comment -%} ── Layout: image 55% / text 45% ── {%- endcomment -%}
    <div class="nve__split" data-sr-block {{ block.shopify_attributes }}>
      <div class="nve__split__img">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image
            | image_url: width: 1400
            | image_tag: loading: 'lazy', alt: block.settings.image.alt | escape
          }}
        {%- else -%}
          <div class="nve__split__img-placeholder"></div>
        {%- endif -%}
      </div>
      <div class="nve__split__text">
        <div class="nve__split__text-inner">
          {%- if block.settings.value_name != blank -%}
            <p class="nve__eyebrow">{{ block.settings.value_name }}</p>
          {%- endif -%}
          {%- if block.settings.headline != blank -%}
            <h2 class="nve__headline" data-sr-h>{{ block.settings.headline }}</h2>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <div class="nve__body">{{ block.settings.body }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- elsif block.type == 'cinematic' -%}
    {%- comment -%} ── Layout: full-bleed image + floating panel ── {%- endcomment -%}
    <div class="nve__cinematic" data-sr-block {{ block.shopify_attributes }}>
      <div class="nve__cinematic__img-wrap">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image
            | image_url: width: 2000
            | image_tag: loading: 'lazy', alt: block.settings.image.alt | escape
          }}
        {%- else -%}
          <div class="nve__cinematic__img-placeholder"></div>
        {%- endif -%}
      </div>
      <div class="nve__cinematic__overlay" aria-hidden="true"></div>
      <div class="nve__cinematic__panel">
        {%- if block.settings.value_name != blank -%}
          <p class="nve__eyebrow">{{ block.settings.value_name }}</p>
        {%- endif -%}
        {%- if block.settings.headline != blank -%}
          <h2 class="nve__headline" data-sr-h>{{ block.settings.headline }}</h2>
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          <div class="nve__body">{{ block.settings.body }}</div>
        {%- endif -%}
      </div>
    </div>

    {%- elsif block.type == 'centered' -%}
    {%- comment -%} ── Layout: centered editorial text ── {%- endcomment -%}
    <div class="nve__centered" data-sr-block {{ block.shopify_attributes }}>
      <div class="nve__centered__inner">
        {%- if block.settings.value_name != blank -%}
          <p class="nve__eyebrow">{{ block.settings.value_name }}</p>
        {%- endif -%}
        {%- if block.settings.headline != blank -%}
          <h2 class="nve__headline" data-sr-h>{{ block.settings.headline }}</h2>
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          <div class="nve__body">{{ block.settings.body }}</div>
        {%- endif -%}
      </div>
    </div>

    {%- endif -%}

  {%- endfor -%}

</section>

<script>
(function() {
  var sec = document.getElementById('nve-{{ section.id }}');
  if (!sec) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var BASE = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/';

  function initReveal() {
    if (!window.__nveGsapReg) {
      gsap.registerPlugin(ScrollTrigger);
      window.__nveGsapReg = true;
    }

    sec.querySelectorAll('[data-sr-h]').forEach(function(el) {
      var text = el.textContent.trim();
      if (!text) return;

      var words = text.split(/(\s+)/);
      el.innerHTML = words.map(function(w) {
        if (/^\s+$/.test(w)) return ' ';
        return '<span class="sr-w">' + w + '</span>';
      }).join('');

      var wordEls = el.querySelectorAll('.sr-w');
      var trigger = el.closest('[data-sr-block]') || el;

      gsap.fromTo(
        wordEls,
        { opacity: 0, filter: 'blur(6px)' },
        {
          opacity: 1,
          filter: 'blur(0px)',
          stagger: 0.05,
          ease: 'none',
          scrollTrigger: {
            trigger: trigger,
            start: 'top 85%',
            end: 'center 45%',
            scrub: true
          }
        }
      );
    });
  }

  function loadScript(src, cb) {
    var existing = document.querySelector('script[data-cm-src="' + src + '"]');
    if (existing) {
      if (window.__cmLoaded && window.__cmLoaded[src]) { cb(); return; }
      existing.addEventListener('load', cb, { once: true });
      return;
    }
    var s = document.createElement('script');
    s.setAttribute('data-cm-src', src);
    s.src = src;
    s.onload = function() {
      window.__cmLoaded = window.__cmLoaded || {};
      window.__cmLoaded[src] = true;
      cb();
    };
    document.head.appendChild(s);
  }

  if (window.gsap && window.ScrollTrigger) {
    initReveal();
  } else if (window.gsap) {
    loadScript(BASE + 'ScrollTrigger.min.js', initReveal);
  } else {
    loadScript(BASE + 'gsap.min.js', function() {
      loadScript(BASE + 'ScrollTrigger.min.js', initReveal);
    });
  }
})();
</script>

{% schema %}
{
  "name": "Valores — Editorial",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "text-full",
      "name": "Texto editorial completo",
      "settings": [
        { "type": "text",         "id": "value_name", "label": "Eyebrow",   "default": "Autenticidad" },
        { "type": "text",         "id": "headline",   "label": "Titular",   "default": "Solo ponemos lo que creemos" },
        { "type": "richtext",     "id": "body",       "label": "Texto",
          "default": "<p>Trabajamos únicamente con lo que creemos. Si un producto no nos convence en la primera prueba, no llega a nuestra tienda.</p><p>La autenticidad no es un valor que se declara, es una práctica que se ejerce cada vez que decimos no a algo que no da la talla.</p>"
        }
      ]
    },
    {
      "type": "split",
      "name": "Imagen + texto (55/45)",
      "settings": [
        { "type": "image_picker", "id": "image",      "label": "Imagen" },
        { "type": "text",         "id": "value_name", "label": "Eyebrow",   "default": "Respeto" },
        { "type": "text",         "id": "headline",   "label": "Titular",   "default": "Un equilibrio que no se puede romper" },
        { "type": "richtext",     "id": "body",       "label": "Texto",
          "default": "<p>El ibérico nace de un equilibrio: entre el animal y su entorno, entre el productor y su tierra, entre nosotros y el cliente.</p><p>Por eso el respeto es la razón de que trabajemos con los productores que trabajamos.</p>"
        }
      ]
    },
    {
      "type": "cinematic",
      "name": "Imagen + panel flotante",
      "settings": [
        { "type": "image_picker", "id": "image",      "label": "Imagen" },
        { "type": "text",         "id": "value_name", "label": "Eyebrow",   "default": "Exigencia" },
        { "type": "text",         "id": "headline",   "label": "Titular",   "default": "Sin excepciones y sin excusas" },
        { "type": "richtext",     "id": "body",       "label": "Texto",
          "default": "<p>Exigimos lo mismo en la selección del producto, en el envasado, en la logística. El resultado en tu mesa tiene que estar a la altura de la expectativa.</p><p>No es perfeccionismo. Es el respeto mínimo que merece alguien que ha depositado su confianza en nosotros.</p>"
        }
      ]
    },
    {
      "type": "centered",
      "name": "Texto centrado",
      "settings": [
        { "type": "text",         "id": "value_name", "label": "Eyebrow",   "default": "Imaginación" },
        { "type": "text",         "id": "headline",   "label": "Titular",   "default": "La tradición y la innovación no son opuestos" },
        { "type": "richtext",     "id": "body",       "label": "Texto",
          "default": "<p>Son los dos extremos del mismo hilo. Llevamos generaciones aprendiendo de los productores y su saber hacer; al mismo tiempo, reinventamos cómo ese conocimiento llega a ti.</p><p>La imaginación es lo que transforma un legado en algo vivo.</p>"
        }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "aria_label", "label": "Etiqueta accesibilidad", "default": "Nuestros valores" }
  ],
  "presets": [
    {
      "name": "Valores — Editorial",
      "blocks": [
        { "type": "text-full" },
        { "type": "split" },
        { "type": "cinematic" },
        { "type": "centered" }
      ]
    }
  ]
}
{% endschema %}
